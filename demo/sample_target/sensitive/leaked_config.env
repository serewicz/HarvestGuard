# HarvestGuard demo fixture -- every value below is FAKE.
#
# This file exists only so HarvestGuard's sensitive-data classifier
# (classifier/scanner.py) has something to find when scanning
# demo/sample_target/ (see GitHub issue #18 / HG-006: Demo Target). None of
# these values are real credentials, and none of them are working accounts,
# keys, or tokens for any real service. Do not copy anything below into a
# real .env file.
#
# An earlier version of this fixture used a syntactically valid-looking
# Slack token (matching the real xoxb-/xoxp-... shape), and GitHub's
# push protection correctly rejected the push for it -- the same
# secret-scanning behavior HarvestGuard's own product exists to help
# evaluate elsewhere. Working around push protection would have been the
# wrong fix. This version instead keeps every value clearly non-functional:
#   - values shaped like AKIA.../a PEM header still match HarvestGuard's
#     classifier (which only checks *format*, the same as most secret
#     scanners), but use obviously-sequential, non-random filler text no
#     real key-generation process would ever produce;
#   - the Slack/GitHub token lines below are deliberately inert -- they do
#     NOT match any real token format (Slack's xox[baprs]-... prefix or
#     GitHub's gh[pousr]_... prefix), specifically so nothing in this file
#     can be mistaken for a live credential by GitHub or any other scanner.
#     Production detection of those two formats is verified separately in
#     tests/test_classifier.py, using values built at runtime rather than
#     written here as literals, so the *classifier* is proven correct
#     without this *fixture* ever containing a matchable secret.

SUPPORT_EMAIL=demo.user@example.com

password = "FAKE-DEMO-PASSWORD-VALUE-0000000000"

AWS_ACCESS_KEY_ID=AKIAABCDEFGHIJKLMNOP

# PEM header/footer only -- HarvestGuard's Private Key pattern matches the
# header line alone, so the body below is deliberately not valid base64/DER
# content, just a plain fake-content marker.
-----BEGIN RSA PRIVATE KEY-----
NOT-A-REAL-KEY-THIS-IS-FAKE-DEMO-CONTENT-ONLY-DO-NOT-USE
-----END RSA PRIVATE KEY-----

# Intentionally inert placeholders -- see the file header comment above for
# why these do not match Slack's or GitHub's real token formats.
SLACK_TOKEN=FAKE_HARVESTGUARD_SLACK_TOKEN
GITHUB_TOKEN=FAKE_HARVESTGUARD_GITHUB_TOKEN
