{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "HarvestGuardListBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME"
    },
    {
      "Sid": "HarvestGuardReadObjects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/*"
    }
  ]
}
